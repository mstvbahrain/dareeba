generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  company   String?
  createdAt DateTime @default(now())
  reports   Report[]
  payments  Payment[]
}

model UploadedFile {
  id          String   @id @default(cuid())
  reportId    String
  filename    String
  mimeType    String
  size        Int
  storagePath String
  textPreview String?
  createdAt   DateTime @default(now())
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Report {
  id                    String          @id @default(cuid())
  userId                String?
  planKey               String          @default("free-preview")
  status                ReportStatus    @default(PREVIEW)
  businessName          String?
  uploadedValue         Decimal         @default(0)
  estimatedVatDue       Decimal         @default(0)
  estimatedRecoverable  Decimal         @default(0)
  possibleExemption     Decimal         @default(0)
  possibleSavingsLow    Decimal         @default(0)
  possibleSavingsHigh   Decimal         @default(0)
  confidenceScore       Int             @default(0)
  riskLevel             RiskLevel       @default(MEDIUM)
  recommendedNextStep   String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User?           @relation(fields: [userId], references: [id])
  files                 UploadedFile[]
  transactions          Transaction[]
  referrals             ReferralLead[]
  payments              Payment[]
}

model Transaction {
  id                String       @id @default(cuid())
  reportId          String
  supplierName      String?
  invoiceDate       DateTime?
  invoiceNumber     String?
  description       String
  amountBeforeVat   Decimal      @default(0)
  vatAmount         Decimal      @default(0)
  totalAmount       Decimal      @default(0)
  currency          String       @default("BHD")
  category          String?
  customsReference  String?
  vatTreatment      VatTreatment @default(NEEDS_REVIEW)
  confidenceScore   Int          @default(50)
  reasoning         String
  warning           String?
  createdAt         DateTime     @default(now())
  report            Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model PricingPlan {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  priceCents  Int
  currency    String   @default("USD")
  fileLimit   Int
  features    Json
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model VatRule {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  ruleType    String
  value       Json
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model Payment {
  id                String        @id @default(cuid())
  reportId          String?
  userId            String?
  planKey           String
  amountCents       Int
  currency          String        @default("USD")
  provider          String        @default("stripe")
  providerSessionId String?
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  report            Report?       @relation(fields: [reportId], references: [id])
  user              User?         @relation(fields: [userId], references: [id])
}

model ReferralLead {
  id                      String       @id @default(cuid())
  reportId                String
  name                    String
  companyName             String?
  email                   String
  phone                   String
  vatIssueType            String
  preferredContactMethod  String
  status                  LeadStatus   @default(NEW)
  referralFee             Decimal      @default(0)
  percentageCommission    Decimal      @default(0)
  totalExpectedCommission Decimal      @default(0)
  commissionPaid          Boolean      @default(false)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  report                  Report       @relation(fields: [reportId], references: [id])
}

enum ReportStatus {
  PREVIEW
  PAID
  REFERRED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum VatTreatment {
  STANDARD_RATED
  ZERO_RATED
  EXEMPT
  OUTSIDE_SCOPE
  NEEDS_REVIEW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum LeadStatus {
  NEW
  SENT_TO_PARTNER
  CONTACTED
  CONVERTED
  COMMISSION_RECEIVED
}
